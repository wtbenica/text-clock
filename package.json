{
  "name": "text-clock",
  "version": "1.1.2",
  "private": true,
  "description": "A simple text clock for the GNOME Shell",
  "homepage": "https://github.com/wtbenica/text-clock#readme",
  "bugs": {
    "url": "https://github.com/wtbenica/text-clock/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/wtbenica/text-clock.git"
  },
  "license": "GPL-3.0-or-later",
  "author": "Wesley Benica <wesley@benica.dev>",
  "sideEffects": false,
  "type": "module",
  "packageManager": "yarn@4.13.0",
  "scripts": {
    "build": "tsc -p config/tsconfig.json",
    "build:dist": "tsc -p config/tsconfig.json && mkdir -p dist && cp -r media metadata.json schemas locale dist/ && cp -r ui dist/ || true",
    "clean": "rm -rf node_modules dist *.zip yarn.lock package-lock.json",
    "dev": "tsc -p config/tsconfig.json --watch",
    "format": "prettier --write \"**/*.ts\"",
    "install:ext": "make install",
    "lint": "eslint -c config/eslint.config.js \"**/*.ts\" --max-warnings 0",
    "lint:fix": "eslint -c config/eslint.config.js \"**/*.ts\" --fix",
    "pack": "make pack",
    "prepare": "husky",
    "test": "jest --config config/jest.config.cjs",
    "test:coverage": "jest --config config/jest.config.cjs --coverage",
    "test:watch": "jest --config config/jest.config.cjs --watch",
    "docs": "typedoc --options config/typedoc.json",
    "docs:serve": "yarn docs && cd docs && python3 -m http.server 8080",
    "validate": "yarn lint && yarn test && yarn build"
  },
  "dependencies": {
    "@girs/gnome-shell": "49.1.0",
    "ts-node": "^10.9.2"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@girs/gjs": "^4.0.0-beta.40",
    "@types/jest": "30.0.0",
    "@types/node": "25.5.0",
    "@typescript-eslint/eslint-plugin": "8.57.1",
    "@typescript-eslint/parser": "8.57.0",
    "eslint": "10.0.3",
    "husky": "^9.1.7",
    "jest": "30.3.0",
    "jest-util": "^30.3.0",
    "lint-staged": "16.4.0",
    "prettier": "3.8.1",
    "ts-jest": "29.4.6",
    "typedoc": "0.28.17",
    "typescript": "5.9.3"
  },
  "lint-staged": {
    "*.ts": [
      "prettier --write",
      "eslint -c config/eslint.config.js --fix"
    ]
  }
}
